function Backup-Folder {
    [CmdletBinding()]
    param (
        [Parameter(Mandatory = $true)]
        [string[]]$SourceFolder,  # Now accepts an array of folders

        [switch]$Recurse
    )

    # Target drive D directly 
    $DestinationRoot = 'E:'

    # Validate that drive D exists 
    if (-not (Get-WmiObject Win32_Volume | Where-Object { $_.DriveLetter -eq $DestinationRoot })) {
        Write-Warning "Drive E: is not available." 
        return
    }

    foreach ($folder in $SourceFolder) {
        if (-not (Test-Path $folder)) {
            Write-Warning "Source folder not found: $folder"
            continue
        }

        $folderName = Split-Path $folder -Leaf
        $backupFolder = Join-Path -Path $DestinationRoot -ChildPath $folderName

        # Create destination folder if it doesn't exist
        if (-not (Test-Path $backupFolder)) {
            New-Item -ItemType Directory -Path $backupFolder -Force | Out-Null
        }

        # Log file
        $logFile = Join-Path -Path $backupFolder -ChildPath "backup_log.txt"
        Add-Content -Path $logFile -Value "`nBackup started for ${folder}: $(Get-Date)"

        # Copy only new or changed files
        $files = Get-ChildItem -Path $folder -Recurse:$Recurse -File

        foreach ($file in $files) {
            $relativePath = $file.FullName.Substring($folder.Length).TrimStart('\')
            $destinationFile = Join-Path -Path $backupFolder -ChildPath $relativePath
            $destinationDir = Split-Path $destinationFile

            if (-not (Test-Path $destinationDir)) {
                New-Item -ItemType Directory -Path $destinationDir -Force | Out-Null
            }

            if (-not (Test-Path $destinationFile) -or ($file.LastWriteTime -gt (Get-Item $destinationFile).LastWriteTime)) {
                Copy-Item -Path $file.FullName -Destination $destinationFile -Force
                Add-Content -Path $logFile -Value "Copied: $relativePath"
            }
        }

        Add-Content -Path $logFile -Value "Backup completed: $(Get-Date)"
        Write-Host "✅ Backup completed for $folder to $backupFolder" -ForegroundColor Green
    }
}

# Run the backup
Backup-Folder -SourceFolder "C:The folder you want backup", "C:The folder you want backup" -Recurse
